---
import Layout from '../layouts/Layout.astro';
import medias from '../data.json';
---

<Layout uid="home" template="home">
  <div class="page-hero content team">
    <h1
      class="title"
      data-subpage-hero-title
      data-motion-text="true"
      data-motion-text-split="chars"
      data-motion-text-duration="0.75"
    ></h1>
    <button type="button" class="page-hero__scroll-cue" aria-label="Scroll down">
      <svg class="page-hero__scroll-icon" viewBox="0 0 24 48" fill="none" xmlns="http://www.w3.org/2000/svg">
        <line x1="12" y1="4" x2="12" y2="34" stroke="currentColor" stroke-width="1"></line>
        <path d="M7 38 L12 43 L17 38" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </button>
  </div>
  <div data-gallery-container class="container">
    <div class="grid-container">
      <div class="grid">
        <h1
          class="grid__item"
          style="--r: 1; --c: 5; --s: 5;"
          data-text-animation-in-duration="0.5"
          data-text-animation-out-duration="0.4"
          data-text-animation-in-delay="0.4"
          data-text-animation
          data-text-animation-split
        >
          Architecture <br />Peter Zumthor · Chapel
        </h1>
        <a class="grid__item" href="/1" style="--r: 1; --c: 1; --s: 4">
          <img loading="eager" src={medias[0].url} alt="Peter Zumthor" />
          <p data-text-animation>
            Peter Zumthor <br /> Swiss architect (b. 1943)
          </p>
        </a>
        <a class="grid__item" href="/2" style="--r: 2; --c: 4; --s: 3">
          <img loading="eager" src={medias[1].url} alt="Therme Vals" />
          <p data-text-animation>
            Therme Vals <br /> Atmosphere-driven architecture
          </p>
        </a>
        <a class="grid__item" href="/4" style="--r: 3; --c: 3; --s: 4">
          <img loading="eager" src={medias[2].url} alt="Architectural Philosophy" />
          <p data-text-animation>
            Architectural Philosophy <br /> Phenomenology of space
          </p>
        </a>
        <a class="grid__item" href="/5" style="--r: 4; --c: 1; --s: 4">
          <img loading="eager" src={medias[3].url} alt="Chapel Project" />
          <p data-text-animation>
            Chapel Project <br /> Small-scale sacred architecture
          </p>
        </a>
        <p
          class="grid__item"
          style="font-size: 1.45rem; --r: 5; --c: 4; --s: 4;"
          data-text-animation-out-stagger="-0.03"
          data-text-animation
          data-text-animation-split
        >
          Peter Zumthor is a Swiss architect known for his focus on atmosphere, material presence, and sensory experience.
          His work avoids symbolic form, instead emphasizing how spaces are felt through light, texture, and sound.
          The Chapel of Saint Benedict reflects his early exploration of intimate, site-specific architecture.
          It translates emotional and physical perception into minimal architectural form.
        </p>
        <a class="grid__item" href="/6" style="--r: 6; --c: 3; --s: 5">
          <img loading="eager" src={medias[4].url} alt="Architectural Concept" />
          <p data-text-animation>
            Architectural Concept <br /> Space as atmosphere, not object
          </p>
        </a>
        <a class="grid__item" href="/7" style="--r: 7; --c: 4; --s: 4">
          <img loading="eager" src={medias[5].url} alt="Purpose" />
          <p data-text-animation>
            Purpose <br /> A reconstructed place of worship
          </p>
        </a>
        <a class="grid__item" href="/8" style="--r: 8; --c: 1; --s: 3">
          <img loading="eager" src={medias[6].url} alt="Roof Detail" />
          <p data-text-animation>
            Roof Detail <br /> Zinc roof, glulam and clerestory assembly
          </p>
        </a>
        <p
          class="grid__item"
          style="--r: 9; --c: 4; --s: 3;"
          data-text-animation-out-stagger="-0.03"
          data-text-animation
          data-text-animation-split
        >
          The chapel is conceived as a spatial envelope rather than a conventional building.
          Its purpose is to restore a place of worship for the local community after the original chapel was destroyed.
          The design prioritizes intimacy, silence, and emotional continuity.
          It avoids monumentality, focusing instead on presence and experience.
        </p>
        <a class="grid__item" href="/9" style="--r: 10; --c: 4; --s: 5">
          <img loading="eager" src={medias[7].url} alt="Foundation Detail" />
          <p data-text-animation>
            Foundation Detail <br /> Shingle wall, floor build-up and concrete base
          </p>
        </a>
      </div>
    </div>
  </div>
</Layout>
